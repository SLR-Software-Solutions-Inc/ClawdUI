#
# ClawdUI build-time environment template.
# Copy to `.env.local` for local dev (gitignored), or supply values via the
# build environment in CI. Vite picks up VITE_*-prefixed vars automatically
# and inlines them into the frontend bundle.

# Optional: GlitchTip / Sentry-compatible DSN for crash reporting.
# Leave blank to disable telemetry entirely (recommended for forks / local builds).
VITE_GLITCHTIP_DSN=

# Auto-set by the build pipeline (semver tag in CI; 0.0.0 locally).
# Used as the Sentry "release" tag so prod events are grouped per release.
VITE_APP_VERSION=
