# ClawdUI — fastlane build pipeline for macOS.
#
# Env loading
# -----------
# Set SLR_ENV_FILE to point at your dotenv file, otherwise we look for
# `fastlane/.env` (gitignored). Copy `fastlane/.env.template` to get started.
#
#   export SLR_ENV_FILE=~/.config/clawdui/fastlane.env   # optional
#   fastlane mac build_dmg_notarized
#
# Required env vars (validated by setup_env):
#   APPLE_ID            Apple Developer account email
#   TEAM_ID             10-char Apple Team ID
#   ASC_KEY_ID          App Store Connect API key id
#   ASC_ISSUER_ID       App Store Connect API issuer id (UUID)
#   ASC_KEY_FILEPATH    Path to AuthKey_<KID>.p8 on disk
#   MATCH_GIT_URL       fastlane match repo (git@host:org/keystore.git)
#   MATCH_PASSWORD      match encryption password
# Optional:
#   APPLE_TEAM_NAME     human-readable team name (defaults to id-based name)
#   CLAWDUI_BUNDLE_ID   override bundle identifier (default: ca.slrsoft.clawdui)

fastlane_version "2.220.0"

require "dotenv"
dotenv_path = ENV["SLR_ENV_FILE"] || File.join(__dir__, ".env")
Dotenv.load(dotenv_path) if File.exist?(dotenv_path)

default_platform :mac

# ---------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------

REPO_ROOT     = File.expand_path("..", __dir__)
APP_NAME      = "ClawdUI"
BUNDLE_ID     = ENV["CLAWDUI_BUNDLE_ID"] || "ca.slrsoft.clawdui"
TARGET_ARM64  = "aarch64-apple-darwin"
TARGET_X64    = "x86_64-apple-darwin"

def require_env!(*keys)
  missing = keys.select { |k| ENV[k].to_s.strip.empty? }
  return if missing.empty?

  UI.user_error!(<<~MSG)
    Missing required env vars: #{missing.join(", ")}.

    Set them in your dotenv file (default: fastlane/.env, override with
    SLR_ENV_FILE) or export them in the calling shell. See fastlane/.env.template
    for the full list.
  MSG
end

def asc_api_key_json_path
  File.join(__dir__, "apple_api_key.json")
end

def write_asc_api_key_json
  require_env!("ASC_KEY_ID", "ASC_ISSUER_ID", "ASC_KEY_FILEPATH")
  key_path = ENV["ASC_KEY_FILEPATH"]
  UI.user_error!("ASC key file not found at #{key_path}") unless File.exist?(key_path)

  payload = {
    key_id:      ENV["ASC_KEY_ID"],
    issuer_id:   ENV["ASC_ISSUER_ID"],
    key:         File.read(key_path),
    in_house:    false
  }
  File.write(asc_api_key_json_path, JSON.pretty_generate(payload))
  File.chmod(0o600, asc_api_key_json_path)
  asc_api_key_json_path
end

def tauri_build(target:, bundles:)
  Dir.chdir(REPO_ROOT) do
    sh "npm --prefix sidecar run build"
    sh "npm run tauri -- build --target #{target} --bundles #{bundles}"
  end
end

def signed_app_path(target)
  File.join(REPO_ROOT, "src-tauri/target/#{target}/release/bundle/macos/#{APP_NAME}.app")
end

def team_name
  ENV["APPLE_TEAM_NAME"] || "Team #{ENV["TEAM_ID"]}"
end

# ---------------------------------------------------------------------
# Platform: macOS
# ---------------------------------------------------------------------

platform :mac do
  desc "Sanity-check required env vars and ASC API key file."
  lane :setup_env do
    require_env!("APPLE_ID", "TEAM_ID",
                 "ASC_KEY_ID", "ASC_ISSUER_ID", "ASC_KEY_FILEPATH",
                 "MATCH_GIT_URL", "MATCH_PASSWORD")
    write_asc_api_key_json
    UI.success "Env OK. ASC API key written to #{asc_api_key_json_path}."
  end

  desc "Sync App Store signing cert + profile via match (read-only)."
  lane :sync_certs do
    setup_env
    match(
      type:            "appstore",
      app_identifier:  BUNDLE_ID,
      platform:        "macos",
      git_url:         ENV["MATCH_GIT_URL"],
      readonly:        true
    )
    # Developer ID Application is account-level (one per team) and lives in the
    # local login keychain. Match cannot create new Developer ID certs via
    # ConnectAPI; the notarized-DMG lane reads the existing identity directly.
  end

  desc "Register the bundle ID on the Apple Developer Portal (one-time bootstrap)."
  lane :register_bundle_id do
    setup_env
    require "spaceship"

    token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath:  File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token

    existing = Spaceship::ConnectAPI::BundleId.find(BUNDLE_ID) rescue nil
    if existing
      UI.success "Bundle ID #{BUNDLE_ID} already exists."
    else
      Spaceship::ConnectAPI::BundleId.create(
        name:       APP_NAME,
        identifier: BUNDLE_ID,
        platform:   Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS,
        seed_id:    ENV["TEAM_ID"]
      )
      UI.success "Registered #{BUNDLE_ID}."
    end
  end

  desc "Bootstrap match for App Store cert + profile. Run once per match repo."
  lane :match_bootstrap do
    setup_env
    match(
      type:           "appstore",
      app_identifier: BUNDLE_ID,
      platform:       "macos",
      git_url:        ENV["MATCH_GIT_URL"],
      readonly:       false
    )
    UI.success "App Store cert + profile committed to match repo for #{BUNDLE_ID}."
    UI.message "Developer ID Application cert is account-level — already in your login keychain."
  end

  # -------------------------------------------------------------------
  # 1) Mac App Store build
  # -------------------------------------------------------------------
  desc "Build, codesign, and produce a .pkg ready for App Store Connect upload."
  lane :build_appstore do |options|
    setup_env
    target = options[:target] || TARGET_ARM64

    sync_certs

    UI.message "Building unsigned Tauri app for #{target}…"
    tauri_build(target: target, bundles: "app")

    app_path = signed_app_path(target)
    UI.user_error!("Built .app missing at #{app_path}") unless Dir.exist?(app_path)

    appstore_identity  = "Apple Distribution: #{team_name} (#{ENV["TEAM_ID"]})"
    installer_identity = "3rd Party Mac Developer Installer: #{team_name} (#{ENV["TEAM_ID"]})"

    entitlements = File.join(REPO_ROOT, "src-tauri/entitlements.appstore.plist")

    UI.message "Codesigning with #{appstore_identity}…"
    sh %(codesign --force --options runtime --timestamp \
         --sign "#{appstore_identity}" \
         --entitlements "#{entitlements}" \
         --deep \
         "#{app_path}")

    pkg_dir  = File.join(REPO_ROOT, "src-tauri/target/#{target}/release/bundle/macos")
    pkg_path = File.join(pkg_dir, "#{APP_NAME}.pkg")
    UI.message "productbuild → #{pkg_path}"
    sh %(productbuild --component "#{app_path}" /Applications \
         --sign "#{installer_identity}" \
         "#{pkg_path}")

    UI.success "Mac App Store .pkg ready at #{pkg_path}"
    UI.message "Run `fastlane mac upload_appstore pkg:#{pkg_path}` when ready to submit."
  end

  desc "Upload an existing .pkg to App Store Connect via Transporter."
  lane :upload_appstore do |options|
    setup_env
    pkg = options[:pkg] || UI.user_error!("Pass `pkg:<path>` to a signed .pkg.")
    UI.user_error!("pkg not found: #{pkg}") unless File.exist?(pkg)

    deliver(
      api_key_path:                       asc_api_key_json_path,
      pkg:                                pkg,
      app_identifier:                     BUNDLE_ID,
      platform:                           "osx",
      submit_for_review:                  false,
      automatic_release:                  false,
      force:                              true,
      precheck_include_in_app_purchases:  false,
      skip_metadata:                      true,
      skip_screenshots:                   true,
      skip_app_version_update:            true
    )
    UI.success "Uploaded #{pkg} to App Store Connect."
  end

  # -------------------------------------------------------------------
  # 2) Direct-distribution notarized DMG
  # -------------------------------------------------------------------
  desc "Build, codesign with Developer ID, package as DMG, notarize, and staple."
  lane :build_dmg_notarized do |options|
    setup_env
    target = options[:target] || TARGET_ARM64

    UI.message "Phase 1/4: Build .app only (no DMG yet) for #{target}…"
    tauri_build(target: target, bundles: "app")

    app_path = signed_app_path(target)
    UI.user_error!("Built .app missing at #{app_path}") unless Dir.exist?(app_path)

    dev_id_identity = "Developer ID Application: #{team_name} (#{ENV["TEAM_ID"]})"
    entitlements    = File.join(REPO_ROOT, "src-tauri/entitlements.developer-id.plist")

    UI.message "Phase 2/4: Codesign .app with #{dev_id_identity}…"
    sh %(codesign --force --options runtime --timestamp \
         --sign "#{dev_id_identity}" \
         --entitlements "#{entitlements}" \
         --deep \
         "#{app_path}")
    sh %(codesign --verify --strict --verbose=2 "#{app_path}")

    dmg_dir = File.join(REPO_ROOT, "src-tauri/target/#{target}/release/bundle/dmg")
    FileUtils.mkdir_p(dmg_dir)
    Dir["#{dmg_dir}/*.dmg"].each { |stale| FileUtils.rm_f(stale) }

    pkg = JSON.parse(File.read(File.join(REPO_ROOT, "package.json")))
    version  = pkg["version"] || "0.0.0"
    arch_tag = target == TARGET_ARM64 ? "aarch64" : "x64"
    dmg_path = File.join(dmg_dir, "#{APP_NAME}_#{version}_#{arch_tag}.dmg")

    UI.message "Phase 3/4: Build DMG from signed .app → #{dmg_path}"
    sh %(hdiutil create -volname "#{APP_NAME}" \
         -srcfolder "#{app_path}" \
         -ov -format UDZO \
         "#{dmg_path}")

    UI.message "Codesigning DMG container…"
    sh %(codesign --force --timestamp --sign "#{dev_id_identity}" "#{dmg_path}")

    UI.message "Phase 4/4: Notarize #{dmg_path}…"
    sh %(xcrun notarytool submit "#{dmg_path}" \
         --key "#{ENV["ASC_KEY_FILEPATH"]}" \
         --key-id "#{ENV["ASC_KEY_ID"]}" \
         --issuer "#{ENV["ASC_ISSUER_ID"]}" \
         --wait)

    UI.message "Stapling ticket onto .app and .dmg…"
    sh %(xcrun stapler staple "#{app_path}")
    sh %(xcrun stapler staple "#{dmg_path}")
    sh %(xcrun stapler validate "#{app_path}")
    sh %(xcrun stapler validate "#{dmg_path}")

    UI.success "Notarized + stapled DMG ready at #{dmg_path}"
  end

  # -------------------------------------------------------------------
  # 3) Convenience
  # -------------------------------------------------------------------
  desc "Build BOTH artifacts (App Store .pkg + notarized DMG)."
  lane :build_both do |options|
    target = options[:target] || TARGET_ARM64
    build_appstore(target: target)
    build_dmg_notarized(target: target)
    UI.success "Built MAS .pkg + notarized DMG for #{target}."
  end
end
