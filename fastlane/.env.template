# fastlane/.env.template — copy to .env (gitignored) OR source <your-env-file>.
# Do NOT commit the .env file. Do NOT put real values in this template.

# Apple identity
APPLE_ID=
APPLE_TEAM_NAME=
TEAM_ID=

# App Store Connect API key (preferred over Apple ID + 2FA)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_FILEPATH=

# match (encrypted git repo with certs/profiles)
MATCH_GIT_URL=
MATCH_GIT_BRANCH=master
MATCH_PASSWORD=
